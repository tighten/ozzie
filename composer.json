{
    "name": "tighten/ozzie",
    "description": "A dashboard to manage open source projects.",
    "keywords": [
        "open source",
        "laravel",
        "tighten"
    ],
    "homepage": "https://github.com/tighten/ozzie",
    "license": "MIT",
    "type": "project",
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        },
        {
            "type": "package",
            "package": {
                "name": "graham-campbell/github",
                "version": "13.0.1",
                "source": {
                    "url": "https://github.com/GrahamCampbell/Laravel-GitHub.git",
                    "type": "git",
                    "reference": "v13.0.0"
                },
                "require": {
                    "php": "^8.1",
                    "graham-campbell/bounded-cache": "^3.0",
                    "graham-campbell/manager": "^5.2",
                    "guzzlehttp/guzzle": "^7.9.2",
                    "guzzlehttp/psr7": "^2.7.0",
                    "illuminate/contracts": "^10.44 || ^11.0 || ^12.0 || ^13.0",
                    "illuminate/support": "^10.44 || ^11.0 || ^12.0 || ^13.0",
                    "knplabs/github-api": "3.16.*",
                    "lcobucci/jwt": "^5.2",
                    "symfony/cache": "^6.2 || ^7.0"
                },
                "autoload": {
                    "psr-4": {
                        "GrahamCampbell\\GitHub\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "GrahamCampbell\\GitHub\\GitHubServiceProvider"
                        ]
                    }
                }
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-gd": "*",
        "ext-json": "*",
        "davaxi/sparkline": "^2.4",
        "erusev/parsedown": "^1.8",
        "graham-campbell/github": "^13.0",
        "guzzlehttp/guzzle": "^7.10",
        "http-interop/http-factory-guzzle": "^1.2",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/framework": "^13.0",
        "laravel/nova": "^5.0",
        "laravel/slack-notification-channel": "^3.8",
        "laravel/socialite": "^5.25",
        "laravel/tinker": "^3.0",
        "league/commonmark": "^2.8",
        "nesbot/carbon": "^3.11",
        "spatie/laravel-ignition": "^2.11",
        "tightenco/ziggy": "^2.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "spatie/laravel-ray": "^1.43",
        "tightenco/duster": "^3.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php artisan nova:publish",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "lint": [
            "vendor/bin/duster lint"
        ],
        "fix": [
            "vendor/bin/duster fix"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    }
}
